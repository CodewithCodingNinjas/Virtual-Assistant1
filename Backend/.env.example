# ---- Server ----
PORT=5000
NODE_ENV=development
# Comma-separated list of allowed frontend origins (CORS)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- MongoDB ----
# Either MONGODB_URI or MONGODB_URL is accepted by config/db.js
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# ---- JWT ----
JWT_SECRET=your_jwt_secret_key_here

# ---- Cloudinary ----
# NOTE: key names must match config/cloudinary.js exactly
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_CLOUD_KEY=your_api_key
CLOUDINARY_CLOUD_SECRET=your_api_secret

# ---- Gemini (LLM fallback) ----
# Full endpoint URL including the API key query param, as used by gemini.js
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=YOUR_KEY
